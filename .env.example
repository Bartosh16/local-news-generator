# === LLM ===
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_GEMINI_API_KEY=
NEWSAPI_KEY=
PERPLEXITY_KEY=

# === MySQL ===
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_TABLE=articles

# === App ===
CONCURRENCY_LIMIT=5
CRON_SCHEDULE=0 6 * * *
PORT=3000
LOG_LEVEL=info

# === Modele LLM ===
CLASSIFIER_MODEL=gpt-4.1-nano
EDITOR_MODEL=gemini-2.5-flash
COMPILER_MODEL=gpt-4.1-mini

NEWSAPI_ENABLED=true

# === Brave Search (auto-discovery portali) ===
BRAVE_SEARCH_API_KEY=
